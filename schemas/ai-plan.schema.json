{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/ai-plan.schema.json",
  "title": "AIPlan",
  "type": "object",
  "required": ["epic_key", "epic_summary", "stories"],
  "properties": {
    "epic_key": {
      "type": "string",
      "minLength": 1
    },
    "epic_summary": {
      "type": "string",
      "minLength": 1
    },
    "stories": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/story"
      }
    },
    "questions_for_human": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    }
  },
  "$defs": {
    "story": {
      "type": "object",
      "required": [
        "summary",
        "description",
        "labels",
        "acceptance_criteria",
        "dependencies",
        "risks",
        "tasks"
      ],
      "properties": {
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "labels": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "acceptance_criteria": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "dependencies": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "risks": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "tasks": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/task"
          }
        }
      }
    },
    "task": {
      "type": "object",
      "required": [
        "summary",
        "issue_type",
        "labels",
        "repo",
        "workdir",
        "module_scope",
        "definition_of_done",
        "acceptance_criteria",
        "execution_hint",
        "test_command",
        "risk_notes",
        "ai_confidence"
      ],
      "properties": {
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "issue_type": {
          "type": "string",
          "enum": ["Task", "Sub-task"]
        },
        "labels": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "repo": {
          "type": "string",
          "minLength": 1
        },
        "workdir": {
          "type": "string",
          "minLength": 1
        },
        "module_scope": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "definition_of_done": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "acceptance_criteria": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "execution_hint": {
          "type": "string",
          "minLength": 1
        },
        "test_command": {
          "type": "string"
        },
        "risk_notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "ai_confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    }
  }
}
